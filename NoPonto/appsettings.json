{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "GpsPolling": {
    "IntervaloSegundos": 20,
    "TtlSegundos": 90
  },

  "GPS": {
    "API": {
      "BASE_URL": "https://dados.mobilidade.rio/gps/sppo"
    },
    "HTTP_TIMEOUT_SECONDS": 15,
    "HUB": {
      "ROUTE": "/hub/gps"
    }
  }
}
